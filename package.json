{
  "name": "glinet-mqtt-ha",
  "version": "1.0.0",
  "description": "Simple REST API to fetch status data and restart / reboot the router with Home Assistant MQTT integration",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "src": "cross-env node --import tsx src/app.ts",
    "server": "node dist/app.js",
    "build": "rimraf dist && swc src --out-dir dist --strip-leading-paths --ignore **/__tests__",
    "build:watch": "swc src -w --out-dir dist --strip-leading-paths --ignore **/__tests__",
    "start:dev": "concurrently \"npm run build:watch\" \"nodemon --watch 'dist/**/*.js' -e js dist/app.js\"",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=junit",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run src/__tests__/**/*.test.ts",
    "test:integration": "vitest run --config vitest.config.ts src/__tests__/integration",
    "test:integration:watch": "vitest --watch src/__tests__/integration/**/*.test.ts",
    "test:integration:ci": "vitest run src/__tests__/integration/**/*.test.ts --reporter=junit",
    "test:e2e": "vitest run src/__tests__/e2e/e2e.test.ts"
  },
  "keywords": [],
  "author": "Neil Flatley",
  "repository": {
    "url": "https://github.com/neilflatley/glinet-mqtt-ha"
  },
  "license": "MIT",
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.21",
    "@swc/plugin-transform-imports": "^12.8.0",
    "@types/node": "^25.5.2",
    "@types/request": "^2.48.13",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "await-to-js": "^3.0.0",
    "axios": "^1.14.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.7",
    "fastify": "^5.8.4",
    "mqtt": "^5.15.1",
    "picomatch": "^4.0.4",
    "unixpass": "^3.0.1"
  },
  "engines": {
    "node": ">=20.6"
  }
}
